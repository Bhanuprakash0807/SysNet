+// weight = 1024 / (1.25 ^ nice) approximation using integer math
+uint64 nice_to_weight(int nice) {
+    uint64 w = 1024;
+
+    if(nice > 0){
+        for(int i = 0; i < nice; i++){
+            w = w * 4 / 5;   // divide by 1.25
+        }
+    } else if(nice < 0){
+        for(int i = 0; i < -nice; i++){
+            w = w * 5 / 4;   // multiply by 1.25
+        }
+    }
+
+    if(w < 1) w = 1;
+    return w;
+}
+
+
