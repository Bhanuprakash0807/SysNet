+void
+scheduler(void)
+{
+  // struct proc *p;
+  struct cpu *c = mycpu();
+
+  c->proc = 0;
+  for(;;){
+    // The most recent process to run may have had interrupts
+    // turned off; enable them to avoid a deadlock if all
+    // processes are waiting. Then turn them back off
+    // to avoid a possible race between an interrupt
+    // and wfi.
+    intr_on();
+    intr_off();
+    
+    #if SCHEDULER == FCFS
+        struct proc* p;
+        struct proc* min_p=0;
+        for(p=proc;p<&proc[NPROC];p++){
+          acquire(&p->lock);
+          if(p->state!=RUNNABLE){
+            release(&p->lock);
+            continue;
+          }
+          if(!min_p || p->creation_time < min_p->creation_time){
+            if(min_p){
+              release(&min_p->lock);
+            }
+            min_p=p;
+          }
+          else{
+            release(&p->lock);
+          }
+        }
+        if(min_p){
+          min_p->state=RUNNING;
+          c->proc=min_p;
+          swtch(&c->context,&min_p->context);
+          c->proc=0;
+          release(&min_p->lock);
+        }
+        else{
+          asm volatile("wfi");
+        }
+
+    #elif SCHEDULER == CFS
+
+
+    struct proc *p;
+    struct proc *min_p = 0;
+    uint64 min_vruntime = 0;
+    int runnable_count = 0;
+
+    printf("[Scheduler Tick]\n");
+    for(p = proc; p < &proc[NPROC]; p++) {
+    acquire(&p->lock);
+    if(p->state == RUNNABLE) {
+        printf("PID: %d | vRuntime: %ld\n", p->pid, p->vruntime);
+    }
+    release(&p->lock);
+}
+
+    for(p = proc; p < &proc[NPROC]; p++) {
+      acquire(&p->lock);
+      if(p->state == RUNNABLE) {
+        runnable_count++;
+            // printf("PID: %d | vRuntime: %ld\n", p->pid, p->vruntime);
+
+            if(min_p == 0 || p->vruntime < min_vruntime) {
+                if(min_p){
+                  release(&min_p->lock); 
+                } 
+                min_vruntime = p->vruntime;
+                min_p = p;
+            } else {
+                release(&p->lock);
+            }
+        } 
+        else {
+            release(&p->lock);
+        }
+    }
+
+    if(min_p) {
+      printf("--> Scheduling PID %d (lowest vRuntime)\n", min_p->pid);
+
+        const uint64 TARGET_LATENCY = 48;
+        const uint64 MIN_TIME_SLICE = 3;
+
+        uint64 time_slice = (runnable_count > 0) ? TARGET_LATENCY / runnable_count : MIN_TIME_SLICE;
+        if(time_slice < MIN_TIME_SLICE) {
+          time_slice = MIN_TIME_SLICE;
+        }
+
+        min_p->time_slice = time_slice;
+        min_p->slice_start = ticks;
+
+        
+        if(min_p->weight == 0){
+            min_p->weight = nice_to_weight(min_p->nice);  
+
+        }
+      
+      
+        min_p->state = RUNNING;
+        c->proc = min_p;
+        swtch(&c->context, &min_p->context);
+
+      
+        uint64 runtime = ticks - min_p->slice_start;
+        if(runtime > 0 && min_p->weight > 0){
+            min_p->vruntime += (runtime * 1024) / min_p->weight;
+
+        }
+
+        c->proc = 0;
+        release(&min_p->lock);
+    } else {
+      
+        asm volatile("wfi");
+    }
+
+    #else 
+      struct proc *p;
+      int found = 0;
+      for(p = proc; p < &proc[NPROC]; p++) {
+        acquire(&p->lock);
+        if(p->state == RUNNABLE) {
+          // Switch to chosen process.  It is the process's job
+          // to release its lock and then reacquire it
+          // before jumping back to us.
+          p->state = RUNNING;
+          c->proc = p;
+          swtch(&c->context, &p->context);
+
+          // Process is done running for now.
+          // It should have changed its p->state before coming back.
+          c->proc = 0;
+          found = 1;
+        }
+        release(&p->lock);
+      }
+      if(found == 0) {
+        // nothing to run; stop running on this core until an interrupt.
+        asm volatile("wfi");
+      }
+
+  #endif
+  }
+}
